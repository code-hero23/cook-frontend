generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String         @default("EMPLOYEE") // SUPER_ADMIN, MANAGER, EMPLOYEE, SITE_SUPERVISOR
  department    String?
  phone         String?
  status        String         @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  assignedTasks Task[]
  assignedProjects Project[]
  
  sentEmails     Email[] @relation("SentEmails")
  receivedEmails Email[] @relation("ReceivedEmails")
}

model Project {
  id               String        @id @default(uuid())
  projectCode      String        @unique // e.g. PRJ001
  clientPassword   String
  name             String
  
  // Client Details
  clientFirstName  String
  clientLastName   String
  clientEmail      String
  clientPhone      String
  
  // Spouse Details
  spouseName       String?
  spousePhone      String?
  
  // Project Details
  location         String?
  budget           Float?
  paymentPercentage Int          @default(0)
  cpNumber         String?       @unique
  
  // Billing
  billingName      String?
  billingAddress   String?
  billingPhone     String?
  gstin            String?

  // GPS Location
  latitude         Float?
  longitude        Float?

  // Dates
  startDate        DateTime?
  deadline         DateTime?
  handoverDate     DateTime?
  handingOverMonth String?
  handingOverYear  String?
  timelineDuration Int           @default(45) // 30 or 45 days
  
  status           String        @default("ONGOING") // ONGOING, COMPLETED, HOLD
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tasks            Task[]
  messages         Message[]
  images           ProjectImage[]
  documents        ProjectDocument[]
  assignedEmployees User[]
  tickets           Ticket[]
  magicLinks        MagicLink[]
}

model ProjectImage {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProjectDocument {
  id        String   @id @default(uuid())
  url       String
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id]) // Optional link to a specific task
  
  createdAt DateTime @default(now())
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        String       @default("TASK") // TASK, ISSUE
  status      String       @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  priority    String       @default("MEDIUM") // LOW, MEDIUM, HIGH
  stage       String?      // Freezing Mail, Production, etc.
  
  // Relations
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  employeeId  String?
  employee    User?        @relation(fields: [employeeId], references: [id])
  
  // Dates
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  completionFileUrl  String?
  completionFileName String?

  evidence           TaskEvidence[]
  documents          ProjectDocument[]
  ticket             Ticket?
}


model Message {
  id          String   @id @default(uuid())
  content     String
  sender      String   
  senderRole  String   
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  attachments String? // JSON string for [{name, url, type}]
  
  createdAt   DateTime @default(now())
}

model TaskEvidence {
  id        String   @id @default(uuid())
  url       String
  latitude  Float
  longitude Float
  capturedAt DateTime
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())
}

model Email {
  id          String   @id @default(uuid())
  subject     String
  content     String
  
  senderId    String
  sender      User     @relation("SentEmails", fields: [senderId], references: [id])
  
  receiverId  String?
  receiver    User?    @relation("ReceivedEmails", fields: [receiverId], references: [id])
  
  isRead      Boolean  @default(false)
  isDraft     Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  
  attachments String? // JSON string for [{name, url}]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ticket {
  id          String   @id @default(uuid())
  ticketId    String   @unique // User-friendly ID like "TKT-1004"
  
  subject     String
  description String
  category    String   // Help, Complaint, Change Request, Bug
  priority    String   // Low, Medium, High, Urgent
  status      String   @default("Open") // Open, In Progress, Resolved
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  clientEmail String   // Capture email directly in case user isn't logged in, or for notifications
  
  // Attachments
  attachmentUrl String?
  attachmentName String?
  attachmentType String?
  
  // Link to Task (Issue)
  taskId      String?  @unique
  task        Task?    @relation(fields: [taskId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  comments    TicketComment[]
}

model TicketComment {
  id        String   @id @default(uuid())
  content   String
  role      String   // "ADMIN" or "CLIENT"
  senderId  String?  // Optional, mostly for Admins
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MagicLink {
  id        String   @id @default(uuid())
  code      String   @unique
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
