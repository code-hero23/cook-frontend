generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String         @default("EMPLOYEE") // SUPER_ADMIN, MANAGER, EMPLOYEE, SITE_SUPERVISOR, CLIENT_RELATIONSHIP_EXECUTIVE
  department    String?
  phone         String?
  status        String         @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  assignedTasks Task[]
  assignedProjects Project[]
  
  sentEmails     Email[] @relation("SentEmails")
  receivedEmails Email[] @relation("ReceivedEmails")

  resetOTP        String?
  resetOTPExpires DateTime?
  
  pushSubscriptions PushSubscription[]
  bhProjects Project[] @relation("ProjectBH")
  faProjects Project[] @relation("ProjectFA")
  laProjects Project[] @relation("ProjectLA")
  
  creWalkins    WalkinHubEntry[] @relation("CREWalkins")
  bhWalkins     WalkinHubEntry[] @relation("BHWalkins")
  creWorkReports WorkReport[]    @relation("CREWorkReports")
  bhWorkReports WorkReport[]    @relation("BHWorkReports")
  creMonthlyReports CREMonthlyReport[] @relation("CREMonthlyReports")
  architectWalkins WalkinHubEntry[] @relation("ArchitectWalkins")
}

model Project {
  id               String        @id @default(uuid())
  projectCode      String        @unique // e.g. PRJ001
  clientPassword   String
  name             String
  
  // Client Details
  clientFirstName  String
  clientLastName   String
  clientEmail      String
  clientPhone      String
  
  // Spouse Details
  spouseName       String?
  spousePhone      String?
  
  // Project Details
  location         String?
  unitNumber       String?
  block            String?
  floor            String?
  area             String?
  budget           Float?
  paymentPercentage Int          @default(0)
  executionPercentage Int        @default(0)
  cpNumber         String?       @unique
  
  // Billing
  billingName      String?
  billingAddress   String?
  billingPhone     String?
  gstin            String?

  // Business Head
  businessHeadId   String?
  businessHead     User?    @relation("ProjectBH", fields: [businessHeadId], references: [id])

  // Project Tracking
  propertyType     String?  // Residential (Villa), Residential (Apartment), Commercial, Office Space, Retail
  scopeOfWork      String?  // Full Interior, Partial Interior, Renovation
  leadSource       String?  // Walk-in, Referral, Custom String
  salesRep         String?  // Custom String Name
  
  faId             String?
  fa               User?    @relation("ProjectFA", fields: [faId], references: [id])
  laId             String?
  la               User?    @relation("ProjectLA", fields: [laId], references: [id])

  // GPS Location
  latitude         Float?
  longitude        Float?

  // Dates
  startDate        DateTime?
  deadline         DateTime?
  handoverDate     DateTime?
  handingOverMonth String?
  handingOverYear  String?
  timelineDuration Int           @default(45) // 30 or 45 days
  
  status           String        @default("ONGOING") // ONGOING, COMPLETED, HOLD
  createdBy        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tasks            Task[]
  messages         Message[]
  images           ProjectImage[]
  documents        ProjectDocument[]
  assignedEmployees User[]
  tickets           Ticket[]
  magicLinks        MagicLink[]
  activityLogs      ActivityLog[]
  paymentTransactions PaymentTransaction[]
}

model PaymentTransaction {
  id          String   @id @default(uuid())
  amount      Float?
  percentage  Int      // The % this payment unlocked (e.g. 15, 50)
  date        DateTime
  time        String?
  mode        String   // UPI, CASH, BANK_TRANSFER, CHEQUE
  verifiedBy  String   // Name of Admin who verified
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model ProjectImage {
  id        String   @id @default(uuid())
  url       String
  caption   String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ProjectDocument {
  id        String   @id @default(uuid())
  url       String
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull) // Linked task deleted -> Document remains
  
  createdAt DateTime @default(now())
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  type        String       @default("TASK") // TASK, ISSUE
  status      String       @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  priority    String       @default("MEDIUM") // LOW, MEDIUM, HIGH
  stage       String?      // Freezing Mail, Production, etc.
  
  // Relations
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  employeeId  String?
  employee    User?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  
  // Dates
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  completionFileUrl  String?
  completionFileName String?

  evidence           TaskEvidence[]
  documents          ProjectDocument[]
  ticket             Ticket?
}


model Message {
  id          String   @id @default(uuid())
  content     String
  sender      String   
  senderRole  String   
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  attachments String? // JSON string for [{name, url, type}]
  
  createdAt   DateTime @default(now())
}

model TaskEvidence {
  id        String   @id @default(uuid())
  url       String
  latitude  Float
  longitude Float
  capturedAt DateTime
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Email {
  id          String   @id @default(uuid())
  subject     String
  content     String
  
  senderId    String
  sender      User     @relation("SentEmails", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId  String?
  receiver    User?    @relation("ReceivedEmails", fields: [receiverId], references: [id], onDelete: SetNull)
  
  isRead      Boolean  @default(false)
  isDraft     Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  
  attachments String? // JSON string for [{name, url}]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ticket {
  id          String   @id @default(uuid())
  ticketId    String   @unique // User-friendly ID like "TKT-1004"
  
  subject     String
  description String
  category    String   // Help, Complaint, Change Request, Bug
  priority    String   // Low, Medium, High, Urgent
  status      String   @default("Open") // Open, In Progress, Resolved
  
  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  clientEmail String   // Capture email directly in case user isn't logged in, or for notifications
  
  // Attachments
  attachmentUrl String?
  attachmentName String?
  attachmentType String?
  
  // Link to Task (Issue)
  taskId      String?  @unique
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  comments    TicketComment[]
}

model TicketComment {
  id        String   @id @default(uuid())
  content   String
  role      String   // "ADMIN" or "CLIENT"
  senderId  String?  // Optional, mostly for Admins
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MagicLink {
  id        String   @id @default(uuid())
  code      String   @unique
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message   String
  category  String   @default("GENERAL") // GENERAL, TASK, UPLOAD, MILESTONE
  taskId    String?  // Optional link if related to a specific task
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  keys      Json     // Stores { p256dh, auth }
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model WalkinHubEntry {
  id                String   @id @default(uuid())
  creId             String
  cre               User     @relation("CREWalkins", fields: [creId], references: [id])
  architectName     String?
  architectId       String?
  architect         User?    @relation("ArchitectWalkins", fields: [architectId], references: [id])
  bhId              String?
  bh                User?    @relation("BHWalkins", fields: [bhId], references: [id])
  bhName            String?
  clientName        String
  contactNumber     String
  project           String?
  status            String?  @default("ACTIVE") // ACTIVE, COMPLETED
  dateOfVisit       DateTime @default(now())
  dayOfVisit        String?  // Sat/Sun
  tentativeTime     String?
  inTime            String?
  outTime           String?
  showroom          String
  visitStatusMonday String?
  remarks           String?
  outTimeMarkedAt   DateTime?
  whatsappSent      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WorkReport {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  nextFD      DateTime?
  clientName  String
  contact     String
  source      String?
  showroom    String
  status      String?  @default("Y") // Y/N
  faName      String?
  bhId        String?
  bh          User?    @relation("BHWorkReports", fields: [bhId], references: [id])
  bhName      String?
  creId       String?
  cre         User?    @relation("CREWorkReports", fields: [creId], references: [id])
  site        String?
  star        Int      @default(0)
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CREMonthlyReport {
  id          String   @id @default(uuid())
  creId       String
  cre         User     @relation("CREMonthlyReports", fields: [creId], references: [id])
  month       Int      // 1-12
  year        Int
  calls       Int      @default(0)
  srv         Int      @default(0)
  proposals   Int      @default(0)
  orders      Int      @default(0)
  value       Float    @default(0) // Stored in Lakhs or raw, UI handles display
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([creId, month, year])
}

